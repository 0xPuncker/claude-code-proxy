{
  "info": {
    "name": "Claude Code Proxy API",
    "description": "Complete API collection for Claude Code Proxy with usage tracking",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:4181",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "your-api-key-here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check proxy health status and configuration"
          }
        },
        {
          "name": "Usage Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usage?days=7",
              "host": ["{{baseUrl}}"],
              "path": ["usage"],
              "query": [
                {
                  "key": "days",
                  "value": "7"
                }
              ]
            },
            "description": "Get usage statistics for the last 7 days"
          }
        }
      ]
    },
    {
      "name": "Messages API",
      "item": [
        {
          "name": "Create Message (Streaming)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, Claude!\"\n    }\n  ],\n  \"stream\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Create a streaming message request"
          }
        },
        {
          "name": "Create Message (Non-Streaming)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Explain quantum computing in simple terms.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Create a non-streaming message request"
          }
        },
        {
          "name": "Create Message with System Prompt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1024,\n  \"system\": \"You are a helpful assistant that explains complex topics simply.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Explain machine learning.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Create a message with system prompt"
          }
        }
      ]
    },
    {
      "name": "Models & Testing",
      "item": [
        {
          "name": "List Models",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/models",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "models"]
            },
            "description": "List available models"
          }
        },
        {
          "name": "Test with Claude Sonnet 4.6",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 512,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"What is 2+2?\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Test basic request with Claude Sonnet 4.6"
          }
        },
        {
          "name": "Test with Claude Opus 4.6",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-opus-4-6\",\n  \"max_tokens\": 512,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a haiku about coding.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Test request with Claude Opus 4.6"
          }
        },
        {
          "name": "Test with Claude Haiku 4.5",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-haiku-4-5\",\n  \"max_tokens\": 256,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Say hello in 5 languages.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Test request with Claude Haiku 4.5"
          }
        }
      ]
    },
    {
      "name": "Advanced Features",
      "item": [
        {
          "name": "Multi-turn Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Remember the number 42.\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"I'll remember that number is 42.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"What number did I ask you to remember?\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Test multi-turn conversation with context"
          }
        },
        {
          "name": "Long Context Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 4096,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a detailed explanation of how the internet works, including DNS, TCP/IP, and HTTP protocols.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Test with longer context and higher max tokens"
          }
        },
        {
          "name": "Error Handling Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "invalid-key"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 256,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"This should fail with invalid API key.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/messages",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "messages"]
            },
            "description": "Test error handling with invalid API key"
          }
        }
      ]
    },
    {
      "name": "Usage Tracking",
      "item": [
        {
          "name": "Get Daily Usage (7 days)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usage?days=7",
              "host": ["{{baseUrl}}"],
              "path": ["usage"],
              "query": [
                {
                  "key": "days",
                  "value": "7"
                }
              ]
            },
            "description": "Get usage statistics for the last 7 days"
          }
        },
        {
          "name": "Get Daily Usage (30 days)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usage?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["usage"],
              "query": [
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            },
            "description": "Get usage statistics for the last 30 days"
          }
        },
        {
          "name": "Get Recent Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usage/recent?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["usage", "recent"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get the 10 most recent requests"
          }
        }
      ]
    }
  ]
}
{
  "info": {
    "name": "Claude Code Proxy API",
    "description": "Complete API collection for Claude Code Proxy with usage tracking",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4181",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "your-api-key-here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check proxy health status and configuration"
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/health",
                  "host": ["{{baseUrl}}"],
                  "path": ["health"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"healthy\",\n  \"service\": \"Claude Code Proxy\",\n  \"version\": \"1.0.0\",\n  \"uptime\": 1234.56,\n  \"timestamp\": \"2026-04-16T10:30:00.000Z\",\n  \"endpoints\": {\n    \"health\": \"/health\",\n    \"proxy\": \"/v1/messages\",\n    \"usage\": \"/usage\"\n  },\n  \"config\": {\n    \"primary\": \"Z.AI\",\n    \"fallback\": \"Anthropic\",\n    \"port\": 4181,\n    \"models\": 8,\n    \"tracking\": true\n  }\n}"
            }
          ]
        }
      ]
    },
        {
          "name": "Usage Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usage?days=7&limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["usage"],
              "query": [
                {
                  "key": "days",
                  "value": "7",
                  "description": "Number of days to include in statistics"
                },
                {
                  "key": "limit",
                  "value": "100",
                  "description": "Maximum number of recent requests to return"
                }
              ]
            },
            "description": "Get comprehensive usage statistics and recent requests"
          },
          "response": [

# Docker Environment Variables for Claude Code Proxy
# Copy this file to .env and update with your actual values
# Command: cp .env.docker.example .env

# =============================================================================
# PROXY CONFIGURATION
# =============================================================================
# Port for the proxy server (default: 4181)
PROXY_PORT=4181

# Container name for the proxy service
PROXY_CONTAINER_NAME=cc-proxy

# =============================================================================
# API KEYS (REQUIRED)
# =============================================================================
# Z.AI API configuration - Get your API key from https://z.ai
ZAI_API_KEY=your-zai-api-key-here

# Anthropic API configuration - Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database Configuration
POSTGRES_DB=claude_proxy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5432
DB_HOST=cc-db

# Container name for the database service
DB_CONTAINER_NAME=cc-db

# Database Connection Pool Settings
DB_SSL=false
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

# Database Health Check Configuration
DB_HEALTHCHECK_INTERVAL=10s
DB_HEALTHCHECK_TIMEOUT=5s
DB_HEALTHCHECK_RETRIES=5

# =============================================================================
# ADMINER CONFIGURATION (Database Management UI)
# =============================================================================
# Port for Adminer web interface
ADMINER_PORT=8080

# Adminer version (default: latest)
ADMINER_VERSION=latest

# Container name for Adminer service
ADMINER_CONTAINER_NAME=cc-adminer

# Adminer design theme (options: nette, pepa-linha, pappu687, etc.)
ADMINER_DESIGN=nette

# Default database server to connect in Adminer
ADMINER_DEFAULT_SERVER=cc-db

# =============================================================================
# POSTGRESQL CONFIGURATION
# =============================================================================
# PostgreSQL version (default: 15)
POSTGRES_VERSION=15

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: debug, info, warn, error, silent (default: info)
LOG_LEVEL=info

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Node environment (development, production)
NODE_ENV=production

# Restart policy for Docker containers (no, always, on-failure, unless-stopped)
RESTART_POLICY=unless-stopped

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================
# Docker Compose project name (helps with multiple instances)
COMPOSE_PROJECT_NAME=claude-code-proxy

# Docker network name
COMPOSE_NETWORK_NAME=claude-network

# =============================================================================
# USAGE EXAMPLES
# =============================================================================
# Start all services:
#   docker-compose up -d
#
# Start with custom environment file:
#   docker-compose --env-file .env.custom up -d
#
# View logs:
#   docker-compose logs -f cc-proxy
#
# Stop all services:
#   docker-compose down
#
# Stop and remove volumes:
#   docker-compose down -v
#
# Rebuild containers:
#   docker-compose build --no-cache
#
# Access database via Adminer:
#   http://localhost:8080
#   System: PostgreSQL
#   Server: cc-db
#   Username: postgres
#   Password: postgres
#   Database: claude_proxy
#
# Access database via psql:
#   docker-compose exec cc-db psql -U postgres -d claude_proxy
#
# Backup database:
#   docker-compose exec cc-db pg_dump -U postgres claude_proxy > backup.sql
#
# Restore database:
#   docker-compose exec -T cc-db psql -U postgres claude_proxy < backup.sql

{
  "name": "claude-code-proxy",
  "version": "1.0.0",
  "description": "Intelligent API proxy for Anthropic Claude with automatic failover and model mapping",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && prisma generate",
    "start": "node dist/index.js",
    "dev": "tsc && prisma generate && node dist/index.js",
    "watch": "tsc --watch",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "db:migrate": "node dist/database/migrate.js",
    "db:seed": "node dist/database/seed.js",
    "settings:update": "node scripts/update-claude-settings.js",
    "settings:update:bash": "bash scripts/update-claude-settings.sh",
    "settings:backup": "node -e \"const fs=require('fs');const ts=new Date().toISOString().replace(/[:.]/g,'-').split('T')[0]+'_'+new Date().toTimeString().split(' ')[0].replace(/:/g,'');const bp=fs.existsSync(process.env.HOME?`${process.env.HOME}/.claude`:`${process.env.USERPROFILE}/.claude`)?(process.env.HOME||process.env.USERPROFILE)+`/.claude`:null;if(bp){fs.copyFileSync(`${bp}/settings.json`,`${bp}/settings.json.backup.${ts}`);console.log('✅ Backup created:',`${bp}/settings.json.backup.${ts}`);}else{console.log('❌ .claude directory not found');}\"",
    "settings:restore": "ls -t ~/.claude/settings.json.backup.* 2>/dev/null || ls -t ~/AppData/Roaming/../.claude/settings.json.backup.* 2>/dev/null | head -1 | xargs -I {} cp {} ~/.claude/settings.json"
  },
  "keywords": [
    "anthropic",
    "claude",
    "api",
    "proxy",
    "failover",
    "ai",
    "llm",
    "usage-tracking",
    "prisma"
  ],
  "author": "Raul Neiva",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raulneiva/claude-code-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/raulneiva/claude-code-proxy/issues"
  },
  "homepage": "https://github.com/raulneiva/claude-code-proxy#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "files": [
    "dist",
    "prisma",
    "README.md",
    "LICENSE"
  ]
}
